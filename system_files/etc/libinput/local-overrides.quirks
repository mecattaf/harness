[Apple Magic Trackpad 2 (Bluetooth)]
MatchBus=bluetooth
MatchVendor=0x004C
MatchProduct=0x0265
AttrTouchSizeRange=20:10
AttrPressureRange=3:0
AttrPalmSizeThreshold=900
AttrThumbSizeThreshold=700

[Apple Magic Trackpad 2 (USB)]
MatchBus=usb
MatchVendor=0x05AC
MatchProduct=0x0265
AttrTouchSizeRange=20:10
AttrPressureRange=3:0
AttrPalmSizeThreshold=900
AttrThumbSizeThreshold=700
